{
    "$schema": "https://raw.githubusercontent.com/FlintTestMC/flint-core/refs/heads/main/flint-content/test_spec_schema.json", 
    "name": "water_destroys_nonsolid_blocks_in_path", 
    "description": "Water flowing into a non-solid, non-waterloggable block destroys it and replaces it with water. From spreadTo(): if block is not LiquidBlockContainer and not air, beforeDestroyingBlock is called.", 
    "tags": ["destroy", "replace"], 
    "dependencies": [], 
    "setup": {
        "cleanup": {
            "region": [ [0, 0, 0], [6, 3, 4] ]
        }
    }, 
    "timeline": [
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 0, 0], [6, 0, 4] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 0], [6, 2, 0] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 4], [6, 2, 4] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 0], [0, 2, 4] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [6, 1, 0], [6, 2, 4] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        { "at": 0, "do": "place", "pos": [3, 1, 2], "block": {"id": "minecraft:torch"} }, 
        { "at": 1, "do": "place", "pos": [1, 1, 2], "block": {"id": "minecraft:water", "level": 0} }, 
        {
            "at": 30, 
            "do": "assert", 
            "checks": [
                { "pos": [3, 1, 2], "is": {"id": "minecraft:water"} }
            ]
        }
    ]
}

