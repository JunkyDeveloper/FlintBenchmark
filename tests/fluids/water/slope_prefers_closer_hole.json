            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 0], [10, 3, 0] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 6], [10, 3, 6] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 0], [0, 3, 6] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [10, 1, 0], [10, 3, 6] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        {
            "at": 0, 
            "do": "fill", 
            "region": [ [0, 1, 0], [10, 1, 6] ], 
            "with": {"id": "minecraft:stone"}
        }, 
        { "at": 0, "do": "place", "pos": [3, 1, 3], "block": {"id": "minecraft:air"} }, 
        { "at": 0, "do": "place", "pos": [8, 1, 3], "block": {"id": "minecraft:air"} }, 
        { "at": 1, "do": "place", "pos": [5, 2, 3], "block": {"id": "minecraft:water", "level": 0} }, 
        {
            "at": 40, 
