{
    "$schema": "https://raw.githubusercontent.com/FlintTestMC/flint-core/refs/heads/main/flint-content/test_spec_schema.json", 
    "name": "water_slope_prefers_closer_hole", 
    "description": "Water preferentially flows toward a closer drop-off over a further one. In getSpread(), when a direction has shorter slopeDistance, result.clear() removes longer paths and water only flows toward the closest hole.", 
